+# Helios environment configuration

+#

+# DB location (defaults to ./helios_memory.db). Override for containerized deploys

+# or test isolation.

+# HELIOS_DB_PATH=/data/helios_memory.db

+

+# ── LLM (real responses) ─────────────────────────────────────────────

+# Get a FREE OpenRouter API key at: https://openrouter.ai/keys

+# (No credit card required for free tier models.)

+# OPENROUTER_API_KEY=sk-or-v1-...

+

+# Optional: pick a different model. Default is Google Gemini 2.0 Flash Exp (free).

+# Other free options: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-r1:free

+# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

+

+# Optional: override the OpenRouter base URL (e.g., for Azure OpenAI or a proxy)

+# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

+

+# Optional: identify your deployment to OpenRouter (shows on their dashboard)

+# HELIOS_PUBLIC_URL=https://your-helios.example.com

+

+# ── Test / dev modes ────────────────────────────────────────────────

+# Force mock LLM responses (used by pytest; never set in production)

+# HELIOS_LLM_MOCK=1

