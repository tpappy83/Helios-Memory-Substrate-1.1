+

+def test_unauthenticated_honors_fallback_namespace():

+    ctx = tenants_mod.resolve_tenant_context(api_key_header=None, fallback_namespace="custom")

+    assert ctx.tenant_id == "custom"

+    assert ctx.authenticated is False

